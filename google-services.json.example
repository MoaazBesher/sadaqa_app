{
  "_comment": "⚠️ Copy this to android/app/google-services.json and fill in your values from Firebase Console",
  "project_info": {
    "project_number": "YOUR_PROJECT_NUMBER",
    "firebase_url":   "https://YOUR_PROJECT_ID-default-rtdb.firebaseio.com",
    "project_id":     "YOUR_PROJECT_ID",
    "storage_bucket": "YOUR_PROJECT_ID.firebasestorage.app"
  },
  "client": [
    {
      "client_info": {
        "mobilesdk_app_id": "YOUR_ANDROID_APP_ID",
        "android_client_info": {
          "package_name": "com.yourcompany.sadaqa_site"
        }
      },
      "oauth_client": [],
      "api_key": [
        {
          "current_key": "YOUR_ANDROID_API_KEY"
        }
      ],
      "services": {
        "appinvite_service": {
          "other_platform_oauth_client": []
        }
      }
    }
  ],
  "configuration_version": "1"
}
